# Copy to .env.local (root) AND apps/worker/.env for local dev.
# Frontend (public, safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Clerk (frontend)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Worker only (server-side, NEVER expose to browser)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Worker tuning
POLL_INTERVAL_MS=30000
# Optional OpenSky auth (increases rate limits). Leave blank for anon polling.
OPENSKY_USERNAME=
OPENSKY_PASSWORD=
# Optional bounding box (minLat,maxLat,minLon,maxLon). Blank = global.
OPENSKY_BBOX=
