SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
POLL_INTERVAL_MS=30000

# Optional OpenSky basic auth (higher rate limits)
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# Optional bounding box (minLat,maxLat,minLon,maxLon) — blank = global
# Example (continental US): 24,50,-125,-66
OPENSKY_BBOX=
